# Frontend build-time config.
# Leave blank for same-origin /api requests, which is what local Vite proxy uses.
# Set to your deployed backend origin when the frontend and backend are hosted separately.
VITE_AUTOOUTLOOK_API_BASE=

# Backend runtime config.
AUTOOUTLOOK_HOST=0.0.0.0
AUTOOUTLOOK_PORT=8765

# Comma-separated frontend origins allowed to call /api.
# Example: https://autooutlook.example.com,https://autooutlook.vercel.app
AUTOOUTLOOK_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional artifact locations for persistent disks/volumes.
# AUTOOUTLOOK_ARTIFACT_DIR=/var/lib/autooutlook/artifacts/latest
# AUTOOUTLOOK_INCREMENTAL_ARTIFACT_DIR=/var/lib/autooutlook/artifacts/latest_incremental
